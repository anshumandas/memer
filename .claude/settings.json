{
  "permissions": {
    "allow": [
      "Bash(flutter:*)",
      "Bash(dart:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Read",
      "Edit"
    ],
    "deny": [
      "Read(.env)",
      "Read(**/*.keystore)",
      "Read(**/*.jks)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "dart format . >/dev/null 2>&1 || true"
          }
        ]
      }
    ]
  }
}
